{
  "info": {
    "name": "Restaurant Ordering System – API Contract",
    "description": "Postman Collection chuẩn cho TV2/TV3/TV4 phát triển song song.\n\n## Hướng dẫn sử dụng\n1. Import file này vào Postman\n2. Chọn Environment \"ROS Local\"\n3. Chạy request \"Login (Admin)\" trước → token tự động lưu vào biến `{{token}}`\n4. Mọi request còn lại sẽ tự gắn Bearer token\n\n## Tài khoản demo\n- Admin: `admin@example.com` / `password123`\n- Cashier: `cashier@example.com` / `password123`\n- Waiter: `waiter@example.com` / `password123`\n- Kitchen: `kitchen@example.com` / `password123`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "ros-tv1"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "restaurant_id", "value": "b09b65cb-9e46-4842-b30d-5ad33efa6ad1", "type": "string" },
    { "key": "table_id", "value": "", "type": "string" },
    { "key": "order_id", "value": "", "type": "string" },
    { "key": "order_item_id", "value": "", "type": "string" },
    { "key": "bill_id", "value": "", "type": "string" },
    { "key": "menu_item_id", "value": "a28660a8-4b9d-48f4-9123-97669a6dc46d", "type": "string" },
    { "key": "waiter_user_id", "value": "8841cb36-e7e3-4a93-8503-b7655371a1a3", "type": "string" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  console.log('Token saved:', res.data.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Cashier)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cashier@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Kitchen)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kitchen@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Waiter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"waiter@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] }
          }
        }
      ]
    },
    {
      "name": "MENU (Public)",
      "item": [
        {
          "name": "Get Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menu/items",
              "host": ["{{base_url}}"],
              "path": ["menu", "items"],
              "query": [
                { "key": "available", "value": "true", "description": "Lọc món còn phục vụ" },
                { "key": "category_id", "value": "", "disabled": true }
              ]
            },
            "description": "Public endpoint – không cần token. Trả về danh sách món kèm variant và modifier."
          }
        },
        {
          "name": "Get Menu Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/menu/categories", "host": ["{{base_url}}"], "path": ["menu", "categories"] }
          }
        },
        {
          "name": "[Admin] Create Menu Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bánh Mì Thịt\",\n  \"category_id\": \"<CATEGORY_ID>\",\n  \"base_price\": 45000,\n  \"kds_zone\": \"kitchen\",\n  \"is_available\": true,\n  \"image_url\": null\n}"
            },
            "url": { "raw": "{{base_url}}/menu/items", "host": ["{{base_url}}"], "path": ["menu", "items"] }
          }
        },
        {
          "name": "[Admin] Toggle is_available",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": false\n}"
            },
            "url": { "raw": "{{base_url}}/menu/items/{{menu_item_id}}", "host": ["{{base_url}}"], "path": ["menu", "items", "{{menu_item_id}}"] }
          }
        },
        {
          "name": "[Admin] Add Variant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Size L\",\n  \"extra_price\": 10000\n}"
            },
            "url": { "raw": "{{base_url}}/menu/items/{{menu_item_id}}/variants", "host": ["{{base_url}}"], "path": ["menu", "items", "{{menu_item_id}}", "variants"] }
          }
        },
        {
          "name": "[Admin] Add Modifier",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Thêm trứng\",\n  \"extra_price\": 5000,\n  \"is_required\": false\n}"
            },
            "url": { "raw": "{{base_url}}/menu/items/{{menu_item_id}}/modifiers", "host": ["{{base_url}}"], "path": ["menu", "items", "{{menu_item_id}}", "modifiers"] }
          }
        }
      ]
    },
    {
      "name": "TABLES",
      "item": [
        {
          "name": "Get All Tables",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('table_id', res.data[0].id);",
                  "  console.log('Table ID saved:', res.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tables", "host": ["{{base_url}}"], "path": ["tables"] },
            "description": "Lấy danh sách bàn kèm trạng thái. Tự động lưu table_id đầu tiên vào biến."
          }
        },
        {
          "name": "[Admin] Create Table",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('table_id', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zone\": \"Sân Vườn\",\n  \"number\": 99,\n  \"restaurant_id\": \"{{restaurant_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/tables", "host": ["{{base_url}}"], "path": ["tables"] }
          }
        },
        {
          "name": "[Admin] Download QR PNG",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tables/{{table_id}}/qr", "host": ["{{base_url}}"], "path": ["tables", "{{table_id}}", "qr"] },
            "description": "Trả về file PNG. Postman tự hiển thị ảnh QR trong tab Body."
          }
        }
      ]
    },
    {
      "name": "ORDERS",
      "item": [
        {
          "name": "Create Order (DINE_IN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('order_id', res.data.id);",
                  "  if (res.data.items && res.data.items.length > 0) {",
                  "    pm.collectionVariables.set('order_item_id', res.data.items[0].id);",
                  "  }",
                  "  console.log('Order ID:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_id\": \"{{table_id}}\",\n  \"customer_name\": \"Khách Demo\",\n  \"phone\": \"0909000000\",\n  \"type\": \"DINE_IN\",\n  \"items\": [\n    {\n      \"menu_item_id\": \"{{menu_item_id}}\",\n      \"qty\": 2,\n      \"note\": \"Ít mỡ, nhiều hành\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] },
            "description": "Public endpoint – không cần token (khách tự gọi móna). Lưu tự động order_id và order_item_id."
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["orders", "{{order_id}}"] }
          }
        },
        {
          "name": "Update Item Status → PREPARING",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"PREPARING\"\n}" },
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}/items/{{order_item_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}", "items", "{{order_item_id}}", "status"]
            },
            "description": "Role: kitchen / waiter / admin"
          }
        },
        {
          "name": "Update Item Status → READY",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"READY\"\n}" },
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}/items/{{order_item_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}", "items", "{{order_item_id}}", "status"]
            },
            "description": "Khi READY → WebSocket push tới /ws/staff/{user_id}"
          }
        },
        {
          "name": "Update Item Status → SERVED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SERVED\"\n}" },
            "url": {
              "raw": "{{base_url}}/orders/{{order_id}}/items/{{order_item_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{order_id}}", "items", "{{order_item_id}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "BILLING",
      "item": [
        {
          "name": "Create Bill",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('bill_id', res.data.id);",
                  "  console.log('Bill ID:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"{{order_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/billing/create", "host": ["{{base_url}}"], "path": ["billing", "create"] },
            "description": "Tự động tính subtotal + VAT + service_fee từ restaurant.settings."
          }
        },
        {
          "name": "Split Bill Evenly",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bill_id\": \"{{bill_id}}\",\n  \"num_people\": 3\n}"
            },
            "url": { "raw": "{{base_url}}/billing/split", "host": ["{{base_url}}"], "path": ["billing", "split"] },
            "description": "Chia đều tổng tiền cho N người. Người cuối trả phần dư (làm tròn)."
          }
        },
        {
          "name": "Checkout – CASH",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bill_id\": \"{{bill_id}}\",\n  \"payment_method\": \"CASH\",\n  \"paid_amount\": 500000\n}"
            },
            "url": { "raw": "{{base_url}}/billing/checkout", "host": ["{{base_url}}"], "path": ["billing", "checkout"] },
            "description": "Thanh toán xong → bàn tự về EMPTY qua WebSocket POS."
          }
        }
      ]
    },
    {
      "name": "INVENTORY",
      "item": [
        {
          "name": "Get Ingredients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/inventory/ingredients", "host": ["{{base_url}}"], "path": ["inventory", "ingredients"] }
          }
        },
        {
          "name": "[Admin] Create Ingredient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bột mì\",\n  \"unit\": \"gram\",\n  \"stock_qty\": 5000,\n  \"alert_threshold\": 500\n}"
            },
            "url": { "raw": "{{base_url}}/inventory/ingredients", "host": ["{{base_url}}"], "path": ["inventory", "ingredients"] }
          }
        },
        {
          "name": "[Admin] Config BOM",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menu_item_id\": \"{{menu_item_id}}\",\n  \"variant_id\": null,\n  \"items\": [\n    {\n      \"ingredient_id\": \"<INGREDIENT_ID>\",\n      \"qty_required\": 200\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/inventory/bom", "host": ["{{base_url}}"], "path": ["inventory", "bom"] },
            "description": "Gán nguyên liệu và định lượng cho từng món (có thể theo variant)."
          }
        }
      ]
    },
    {
      "name": "RESERVATIONS",
      "item": [
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_id\": \"{{table_id}}\",\n  \"customer_name\": \"Nguyễn Văn A\",\n  \"phone\": \"0901234567\",\n  \"reserved_at\": \"2026-03-25T18:00:00+07:00\",\n  \"party_size\": 4,\n  \"note\": \"Ngồi gần cửa sổ\"\n}"
            },
            "url": { "raw": "{{base_url}}/reservations", "host": ["{{base_url}}"], "path": ["reservations"] },
            "description": "Public endpoint – không cần token."
          }
        },
        {
          "name": "[Staff] Confirm Reservation",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" },
            "url": {
              "raw": "{{base_url}}/reservations/<RESERVATION_ID>/confirm",
              "host": ["{{base_url}}"],
              "path": ["reservations", "<RESERVATION_ID>", "confirm"]
            }
          }
        },
        {
          "name": "[Staff] Check-in → Trigger Pre-order KDS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/reservations/<RESERVATION_ID>/checkin",
              "host": ["{{base_url}}"],
              "path": ["reservations", "<RESERVATION_ID>", "checkin"]
            },
            "description": "Khách đến nhà hàng. Bàn OCCUPIED, pre-order đẩy xuống KDS ngay lập tức."
          }
        }
      ]
    },
    {
      "name": "WEBSOCKET – Test Endpoints",
      "item": [
        {
          "name": "WS – KDS Kitchen",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "ws://localhost/ws/kds/kitchen", "protocol": "ws", "host": ["localhost"], "path": ["ws", "kds", "kitchen"] },
            "description": "⚡ Kết nối WebSocket để nhận thẻ món zone bếp.\nDùng Postman WebSocket tab hoặc PieSocket.\n\nSự kiện nhận về:\n{\n  \"event\": \"new_order_items\",\n  \"items\": [ { \"menu_item_name\": \"...\", \"qty\": 2, \"table_id\": \"...\", \"zone\": \"kitchen\" } ]\n}"
          }
        },
        {
          "name": "WS – KDS Bar",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "ws://localhost/ws/kds/bar", "protocol": "ws", "host": ["localhost"], "path": ["ws", "kds", "bar"] }
          }
        },
        {
          "name": "WS – POS Table Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "ws://localhost/ws/pos", "protocol": "ws", "host": ["localhost"], "path": ["ws", "pos"] },
            "description": "⚡ Thu ngân kết nối để nhận event bàn đổi trạng thái.\n\nSự kiện nhận về:\n{\n  \"type\": \"TABLE_STATUS\",\n  \"table_id\": \"...\",\n  \"status\": \"OCCUPIED\" | \"EMPTY\"\n}"
          }
        },
        {
          "name": "WS – Staff Notification",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "ws://localhost/ws/staff/{{waiter_user_id}}",
              "protocol": "ws",
              "host": ["localhost"],
              "path": ["ws", "staff", "{{waiter_user_id}}"]
            },
            "description": "⚡ Nhân viên phục vụ kết nối để nhận push khi món READY.\n\nSự kiện nhận về:\n{\n  \"type\": \"ITEM_READY\",\n  \"table_id\": \"...\",\n  \"menu_item_name\": \"Phở Bò\",\n  \"order_item_id\": \"...\"\n}"
          }
        }
      ]
    }
  ]
}
